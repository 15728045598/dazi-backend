// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

model Participant {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  phone       String
  idCard      String?   // 身份证号
  gender      String?   // 性别
  birthday    DateTime? // 生日
  emergencyContact String? // 紧急联系人
  emergencyPhone   String? // 紧急联系人电话
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== 枚举类型 ====================

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
  DELETED
}

enum UserRole {
  USER
  LEADER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Experience {
  LESS_THAN_1_YEAR
  ONE_TO_3_YEARS
  THREE_TO_5_YEARS
  MORE_THAN_5_YEARS
}

enum LeaderLevel {
  JUNIOR
  MIDDLE
  SENIOR
}

enum LeaderStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REVOKED
}

enum ActivityCategory {
  HIKING
  MOUNTAIN
  CYCLING
  CAMPING
  WATER
  CITY
  OTHER
}

enum Difficulty {
  BEGINNER
  EASY
  MEDIUM
  HARD
}

enum ActivityStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  PUBLISHED
  FULL
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  PAID
  VERIFIED
  COMPLETED
  CANCELLED
  REFUNDING
  REFUNDED
}

enum PointsType {
  SIGN_IN
  STEPS
  INVITE
  TRAVEL
  REVIEW
  LEADING
  HELP
  CHARITY
  DEDUCTION
  EXCHANGE
  GIFT
  EXPIRED
  REFUND
}

enum CouponType {
  CASH
  FULL_REDUCTION
  DISCOUNT
  NEW_USER
  INVITE
}

enum CouponStatus {
  ACTIVE
  PAUSED
  EXPIRED
  DEPLETED
}

enum ContentStatus {
  PENDING
  APPROVED
  REJECTED
  DELETED
}

enum WishType {
  PLACE
  ACTIVITY
  SKILL
  FRIEND
  CUSTOM
}

enum ExpectTime {
  ANYTIME
  THIS_WEEK
  THIS_MONTH
  CUSTOM
}

enum ExpectPeople {
  ANY
  SMALL
  MEDIUM
  LARGE
}

enum WishStatus {
  COLLECTING
  FULL
  CONVERTED
  EXPIRED
  CLOSED
}

enum HelpStatus {
  ACTIVE
  RESPONDED
  COMPLETED
  CLOSED
  DISPUTED
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  SUSPENDED
}

enum MessageType {
  SYSTEM
  ACTIVITY
  ORDER
  POINTS
  INVITE
  COMMUNITY
  CHARITY
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ==================== 用户相关 ====================

model User {
  id              String    @id @default(uuid())
  openid          String    @unique
  unionid         String?   @unique
  phone           String?   @unique
  nickname        String?
  avatar          String?
  status          UserStatus @default(ACTIVE)
  role            UserRole   @default(USER)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastLoginAt     DateTime?
  
  // 积分相关
  points          Int       @default(0)        // 当前可用积分（余额）
  totalPointsEarned Int     @default(0)        // 累计获得积分
  totalPointsUsed Int      @default(0)       // 累计使用积分
  level           Int       @default(1)       // 用户等级（200积分/级）
  consecutiveSignInDays Int @default(0)       // 连续签到天数
  lastSignInDate  DateTime?                    // 上次签到日期
  
  // 统计
  activityCount   Int       @default(0)
  
  // 关联
  profile         UserProfile?
  interests       UserInterest[]
  addresses       UserAddress[]
  leader          Leader?
  orders          Order[]
  pointsAccount   PointsAccount?
  messages        Message[]
  
  // 钱包相关
  wallet          Wallet?
  walletTransactions WalletTransaction[]
  
  // 步数统计
  dailySteps      UserDailySteps[]
  
  // 报名人管理
  participants    Participant[]
  
  // 领队申请
  leaderApplications LeaderApplication[]

  // 合作加入
  partnerApplications PartnerApplication[]

  // 公益相关
  donations       CharityDonation[]
  volunteerParticipations VolunteerParticipation[]
  
  // 邀请相关
  inviteRelationsAsInviter   InviteRelation[]  @relation("InviterRelations")
  inviteRelationsAsInvitee    InviteRelation[]  @relation("InviteeRelations")
  
  // 推广大使
  promoter      Promoter?
  
  // 游记/心愿/互助
  travels        Travel[]
  wishes          Wish[]
  helps           Help[]
  helpResponses   HelpResponse[]
  feedbacks      Feedback[]
  
  @@index([openid])
  @@index([phone])
  @@index([status])
}

model UserProfile {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  realName        String?
  idCard          String?
  gender          Gender?
  birthday        DateTime?
  city            String?
  bio             String?   @db.Text
  experience      Experience?
  
  phoneVisible    Boolean   @default(false)
  activityVisible Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model UserInterest {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  interest    String
  createdAt   DateTime  @default(now())
  
  @@unique([userId, interest])
}

model UserAddress {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  phone       String
  province    String
  city        String
  district    String
  detail      String
  isDefault   Boolean   @default(false)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([userId])
}

// ==================== 领队相关 ====================

enum LeaderApplicationStatus {
  PENDING   // 待审核
  APPROVED  // 已通过
  REJECTED // 已拒绝
}

model Leader {
  id              String      @id @default(uuid())
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  level           LeaderLevel @default(JUNIOR)
  status          LeaderStatus @default(PENDING)
  
  activityCount   Int         @default(0)
  totalParticipants Int       @default(0)
  rating          Float       @default(5.0)
  ratingCount     Int         @default(0)
  points          Int         @default(0)
  
  specialties     Json     @default("[]")
  
  verifiedAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  activities      Activity[]
  activityLeaders ActivityLeader[]
  reviews         LeaderReview[]

  @@index([level])
  @@index([status])
}

model LeaderApplication {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 基础信息
  realName        String
  idCard          String?
  gender          String?   // MALE, FEMALE, OTHER
  age             Int?      // 年龄
  phone           String    // 手机号
  
  // 专业资质
  experience      Experience  // 户外经验年限
  experienceYears String?    // 自定义年限描述
  specialties     Json       @default("[]")  // 擅长领域（多选）
  customSpecialties String?   // 自定义擅长领域
  certificates    Json       @default("[]")  // 资质证书
  
  // 风格与偏好
  leadershipStyle Json       @default("[]")  // 带队风格（多选）
  customStyle     String?     // 自定义带队风格
  availableTime   Json       @default("[]")  // 可带队时间（工作日/周末/节假日）
  
  // 补充说明
  bio             String?    @db.Text
  experienceDesc  String?    @db.Text
  
  // 紧急联系人
  emergencyContact String?
  emergencyPhone  String?
  
  // 状态
  status          LeaderApplicationStatus @default(PENDING)
  rejectReason    String?
  adminNote       String?
  reviewedBy      String?    // 审核人
  reviewedAt      DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([userId])
  @@index([status])
}

model LeaderReview {
  id          String    @id @default(uuid())
  leaderId    String
  leader      Leader    @relation(fields: [leaderId], references: [id], onDelete: Cascade)
  userId      String
  
  rating      Int
  content     String?   @db.Text
  
  createdAt   DateTime  @default(now())
  
  
}

// ==================== 活动相关 ====================

model Activity {
  id              String          @id @default(uuid())
  
  title           String
  summary         String?         @db.Text // 活动简介，显示在列表页
  description     String          @db.Text
  coverImage      String
  groupChatQrCode String?         // 群聊二维码
  
  category        ActivityCategory
  difficulty      Difficulty
  
  startTime       DateTime
  endTime         DateTime
  registerDeadline DateTime
  
  location        String
  locationLat     Float?
  locationLng     Float?
  meetingPoint    String?
  meetingLat      Float?
  meetingLng      Float?
  
  price           Decimal         @db.Decimal(10, 2)
  earlyBirdPrice  Decimal?        @db.Decimal(10, 2)
  earlyBirdEndTime DateTime?
  originalPrice   Decimal?        @db.Decimal(10, 2)
  costBreakdown   Json?
  costIncludes    String?         @db.Text // 费用包含
  costExcludes    String?         @db.Text // 费用不含
  
  tags              Json?            @default("[]")
  locationPoi       Json?
  descriptionImages Json?           @default("[]")
  
  // 参与要求、退款政策、免责声明
  requirements    String?         @db.Text // 参与要求
  refundPolicy    String?         @db.Text // 退款政策
  disclaimer      String?         @db.Text // 免责声明
  
  minParticipants Int             @default(2)
  maxParticipants Int             @default(30)
  currentCount    Int             @default(0)
  
  // Multi-leader support: keep leaderId for backward compatibility (optional)
  leaderId        String?
  leader          Leader?        @relation(fields: [leaderId], references: [id])
  // New multi-leader support
  leaders         ActivityLeader[]
  
  status          ActivityStatus  @default(DRAFT)
  
  isCharity       Boolean         @default(false) // 是否为公益活动
  charityAmount   Decimal         @default(1.00) @db.Decimal(10, 2)
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  images          ActivityImage[]
  schedules       ActivitySchedule[]
  priceTypes      ActivityPriceType[]
  orders          Order[]
  activityRequirementList  ActivityRequirement[]
  travels         Travel[]
  
  @@index([category])
  @@index([status])
  @@index([startTime])
  // note: leaders are now a relation via ActivityLeader join table
  
  expenses    CharityExpense[] // 公益支出记录
}

// 价格类型模型
model ActivityPriceType {
  id          String    @id @default(uuid())
  activityId  String
  activity    Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  name        String    // 票型名称，如"成人票"、"儿童票"、"早鸟票"
  price       Decimal   @db.Decimal(10, 2) // 价格
  description String?   @db.Text // 描述
  stock       Int?      // 库存，为null表示不限量
  sort        Int       @default(0) // 排序
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([activityId])
}

model ActivityLeader {
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  leaderId   String
  leader     Leader   @relation(fields: [leaderId], references: [id], onDelete: Cascade)
  
  @@id([activityId, leaderId])
  @@index([activityId])
  @@index([leaderId])
}

model ActivityImage {
  id          String    @id @default(uuid())
  activityId  String
  activity    Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  url         String
  sort        Int       @default(0)
  createdAt   DateTime  @default(now())
  
  @@index([activityId])
}

model ActivitySchedule {
  id          String    @id @default(uuid())
  activityId  String
  activity    Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  
  day         Int       // 第几天
  time        String    // 时间点
  title       String
  description String?   @db.Text
  
  createdAt   DateTime  @default(now())
  
  @@index([activityId])
}

model ActivityRequirement {
  id          String    @id @default(uuid())
  activityId  String
  activity    Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  
  type        String    // equipment | notice | safety
  content     String
  
  createdAt   DateTime  @default(now())
  
  @@index([activityId])
}

// ==================== 订单相关 ====================

model Order {
  id              String      @id @default(uuid())
  orderNo         String      @unique
  
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  activityId      String
  activity        Activity    @relation(fields: [activityId], references: [id])
  
  quantity        Int         @default(1)
  
  // 价格类型
  priceTypeId     String?     // 选中的价格类型ID
  priceTypeName   String?     // 选中的价格类型名称
  
  originalAmount  Decimal     @db.Decimal(10, 2)
  couponDiscount  Decimal     @default(0) @db.Decimal(10, 2)
  couponId       String?     // 使用的优惠券ID
  pointsDiscount  Decimal     @default(0) @db.Decimal(10, 2)
  pointsUsed      Int         @default(0)
  charityAmount   Decimal     @default(0) @db.Decimal(10, 2)
  finalAmount     Decimal     @db.Decimal(10, 2)
  
  status          OrderStatus @default(PENDING)
  
  paidAt          DateTime?
  verifiedAt      DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  
  refundAmount    Decimal?    @db.Decimal(10, 2)
  refundReason    String?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  participants    OrderParticipant[]
  payments        Payment[]
  refunds         Refund[]
  verification    Verification?
  
  @@index([userId])
  @@index([activityId])
  @@index([status])
  @@index([orderNo])
  @@index([createdAt])
}

model OrderParticipant {
  id          String    @id @default(uuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  name        String
  phone       String
  idCard      String?
  emergencyContact String?
  emergencyPhone   String?
  
  createdAt   DateTime  @default(now())
  
  @@index([orderId])
}

model Payment {
  id          String    @id @default(uuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  paymentNo   String    @unique
  amount      Decimal   @db.Decimal(10, 2)
  channel     String    // WECHAT_PAY
  status      String    // SUCCESS | FAILED
  paidAt      DateTime?
  
  createdAt   DateTime  @default(now())
  
  @@index([orderId])
}

model Refund {
  id          String    @id @default(uuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  refundNo    String    @unique
  amount      Decimal   @db.Decimal(10, 2)
  reason      String?
  status      String    // PENDING | SUCCESS | FAILED
  refundedAt  DateTime?
  
  createdAt   DateTime  @default(now())
  
  @@index([orderId])
}

model Verification {
  id          String    @id @default(uuid())
  orderId     String    @unique
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  code        String    // 核销码
  verifiedBy  String?   // 核销人
  verifiedAt  DateTime?
  
  createdAt   DateTime  @default(now())
}

// ==================== 积分相关 ====================

model PointsAccount {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  balance     Int       @default(0)
  totalEarned Int       @default(0)
  totalUsed   Int       @default(0)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  transactions PointsTransaction[]
}

model PointsTransaction {
  id          String    @id @default(uuid())
  
  accountId   String
  account     PointsAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userId      String
  
  type        PointsType
  amount      Int
  balance     Int
  
  sourceId    String?
  sourceType  String?
  
  title       String
  description String?
  
  expiredAt   DateTime?
  
  createdAt   DateTime  @default(now())
  
  @@index([accountId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ==================== 优惠券相关 ====================

model Coupon {
  id              String      @id @default(uuid())
  
  name            String
  description     String?
  
  type            CouponType
  value           Decimal     @db.Decimal(10, 2)
  minAmount       Decimal?    @db.Decimal(10, 2)
  maxDiscount     Decimal?    @db.Decimal(10, 2)
  
  validDays       Int
  startTime       DateTime?
  endTime         DateTime?
  
  totalCount      Int?
  issuedCount     Int         @default(0)
  userLimit       Int         @default(1)
  
  applicableCategories Json @default("[]")
  
  status          CouponStatus @default(ACTIVE)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  userCoupons     UserCoupon[]
}

model UserCoupon {
  id          String    @id @default(uuid())
  
  userId      String
  couponId    String
  coupon      Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  
  status      String    @default("UNUSED") // UNUSED | USED | EXPIRED
  usedAt      DateTime?
  orderId     String?
  
  startTime   DateTime
  endTime     DateTime
  
  createdAt   DateTime  @default(now())
  
  @@index([userId])
  @@index([couponId])
  @@index([status])
}

// 公益文章
model CharityArticle {
  id          String    @id @default(uuid())
  title       String
  summary     String?   @db.Text
  coverImage  String?
  content     String    @db.Text
  views       Int       @default(0)
  published   Boolean   @default(true)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// 公益活动
model CharityCampaign {
  id            String    @id @default(uuid())
  title         String
  description   String    @db.Text
  coverImage    String?
  
  targetAmount  Decimal   @db.Decimal(10, 2)
  raisedAmount  Decimal   @default(0) @db.Decimal(10, 2)
  
  status        String    @default("PLANNED") // PLANNED | FUNDED | IN_PROGRESS | COMPLETED | CANCELLED
  
  startDate     DateTime
  endDate       DateTime?
  
  proofImages   Json      @default("[]")
  expenseDesc   String?   @db.Text
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  donations     CharityDonation[]
  expenses      CharityExpense[]
  volunteers    VolunteerParticipation[]
  
  @@index([status])
}

// 捐赠记录
model CharityDonation {
  id          String    @id @default(uuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  campaignId  String?
  campaign    CharityCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  
  amount      Decimal   @db.Decimal(10, 2)
  type        String    // PLATFORM_REGISTRATION | USER_DONATION | PLATFORM_DONATION
  orderId     String?
  note        String?
  
  createdAt   DateTime  @default(now())
  
  @@index([userId])
  @@index([campaignId])
}

// 公益支出
model CharityExpense {
  id          String    @id @default(uuid())
  campaignId  String?   // 旧版公益项目
  campaign    CharityCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  activityId  String?   // 关联公益活动（Activity）
  activity    Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)
  
  amount      Decimal   @db.Decimal(10, 2)
  purpose     String?   @db.Text
  beneficiary String?   @db.Text
  description String?   @db.Text
  proofImages Json      @default("[]")
  
  createdAt   DateTime  @default(now())
  
  @@index([campaignId])
  @@index([activityId])
}

// 公益账户
model PublicFund {
  id            String    @id @default(uuid())
  totalDonated  Decimal   @default(0) @db.Decimal(10, 2)
  totalSpent    Decimal   @default(0) @db.Decimal(10, 2)
  balance       Decimal   @default(0) @db.Decimal(10, 2)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  transactions  PublicFundTransaction[]
}

// 公益资金变动记录
model PublicFundTransaction {
  id            String    @id @default(uuid())
  fundId        String
  fund          PublicFund @relation(fields: [fundId], references: [id], onDelete: Cascade)
  
  type          String    // DONATION | EXPENSE | ADJUSTMENT
  amount        Decimal   @db.Decimal(10, 2)
  balance       Decimal   @db.Decimal(10, 2)
  
  description   String?
  relatedId     String?
  relatedType   String?
  
  createdAt     DateTime  @default(now())
  
  @@index([fundId])
  @@index([type])
}

// 志愿者参与
model VolunteerParticipation {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  campaignId  String
  campaign    CharityCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  
  hours       Int       @default(0)
  status      String    @default("PENDING") // PENDING | CONFIRMED | COMPLETED
  
  createdAt   DateTime  @default(now())
  
  @@index([userId])
  @@index([campaignId])
}

// 旧版公益项目（保留兼容，不建立关联）
model CharityProject {
  id              String      @id @default(uuid())
  
  name            String
  description     String      @db.Text
  coverImage      String?
  
  targetAmount    Decimal     @db.Decimal(10, 2)
  raisedAmount    Decimal     @default(0) @db.Decimal(10, 2)
  
  status          ProjectStatus @default(ACTIVE)
  
  startTime       DateTime
  endTime         DateTime?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([status])
}

// 旧版捐赠记录（兼容）
model CharityApplication {
  id          String    @id @default(uuid())
  
  userId      String
  
  type        String    // MUTUAL_AID | EMERGENCY
  description String    @db.Text
  proofImages Json     @default("[]")
  amount      Decimal   @db.Decimal(10, 2)
  bankAccount String
  
  status      String    @default("PENDING") // PENDING | APPROVED | REJECTED
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([userId])
  @@index([status])
}

// ==================== 消息相关 ====================

model Message {
  id          String    @id @default(uuid())
  
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        MessageType
  title       String
  content     String    @db.Text
  
  sourceId    String?
  sourceType  String?
  
  isRead      Boolean   @default(false)
  readAt      DateTime?
  
  pushed      Boolean   @default(false)
  pushedAt    DateTime?
  
  createdAt   DateTime  @default(now())
  
  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

model Banner {
  id          String    @id @default(uuid())
  
  title       String
  image       String
  link        String?   // 跳转链接
  linkType    String?   // ACTIVITY | URL | PAGE
  
  position    String    @default("HOME") // HOME | DISCOVER
  sort        Int       @default(0)
  
  startTime   DateTime?
  endTime     DateTime?
  
  status      String    @default("ACTIVE")
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([position])
  @@index([status])
}

// ==================== 钱包相关 ====================

model Wallet {
  id          String    @id @default(uuid())
  
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  balance     Decimal   @db.Decimal(10, 2) @default(0)
  totalRecharge Decimal @db.Decimal(10, 2) @default(0)
  totalSpend   Decimal  @db.Decimal(10, 2) @default(0)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  transactions WalletTransaction[]
  
  @@index([userId])
}

model WalletTransaction {
  id          String    @id @default(uuid())
  
  walletId    String
  wallet      Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        String    // RECHARGE | SPEND | REFUND | ACTIVITY_PAY | CHARITY_DONATE | INVITE_REWARD | OTHER
  amount      Decimal   @db.Decimal(10, 2)
  balance     Decimal   @db.Decimal(10, 2)  // 交易后余额
  
  description String?
  orderId     String?   // 关联订单
  relatedId   String?   // 关联ID（如活动ID、捐赠ID等）
  
  status      String    @default("SUCCESS") // PENDING | SUCCESS | FAILED
  
  createdAt   DateTime  @default(now())
  
  @@index([walletId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ==================== 步数统计 ====================

model UserDailySteps {
  id          String    @id @default(uuid())
  
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  date        String    // YYYY-MM-DD 格式
  steps       Int       @default(0)
  earnedPoints Int      @default(0)  // 今日已兑换的积分
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// ==================== 合作加入 ====================

enum PartnerStatus {
  PENDING    // 待审核
  APPROVED   // 已通过
  REJECTED   // 已拒绝
}

model PartnerApplication {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 合作类型
  partnerType String       // RESOURCE:资源合作, CONTENT:内容合作, BUSINESS:商务合作, OTHER:其他
  
  // 个人/机构信息
  name        String        // 姓名或机构名称
  contact     String       // 联系方式（手机号）
  email       String?       // 邮箱（可选）
  company     String?       // 公司/组织（可选）
  position    String?       // 职位（可选）
  
  // 合作内容
  resources   String       @db.Text  // 可以带来的资源或能力介绍
  expectCooperation String? @db.Text // 期望的合作方式
  
  // 状态
  status      PartnerStatus @default(PENDING)
  adminNote   String?       // 管理员备注
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  @@index([userId])
  @@index([status])
}

// ==================== 游记相关 ====================

model Travel {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title       String
  content     String        @db.Text
  coverImage  String?
  images      Json          @default("[]")  // JSON格式图片列表
  location    String?
  locationLat Float?
  locationLng Float?
  
  // 关联活动（可选）
  activityId  String?
  activity    Activity?   @relation(fields: [activityId], references: [id], onDelete: SetNull)
  
  status      ContentStatus @default(PENDING)
  views       Int           @default(0)
  viewCount   Int           @default(0)   // 浏览次数
  likes       Int           @default(0)
  likeCount   Int           @default(0)   // 点赞数
  commentCount Int         @default(0)   // 评论数
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  // 关联
  comments    TravelComment[]
  likes_      TravelLike[]
  imageList   TravelImage[] @relation("TravelImages")  // 单独的图片表
  
  @@index([userId])
  @@index([status])
  @@index([activityId])
}

model TravelComment {
  id          String    @id @default(uuid())
  travelId    String
  travel      Travel    @relation(fields: [travelId], references: [id], onDelete: Cascade)
  userId      String
  
  content     String    @db.Text
  parentId    String?   // 回复某条评论
  
  createdAt   DateTime  @default(now())
  
  @@index([travelId])
}

model TravelImage {
  id          String    @id @default(uuid())
  travelId    String
  travel      Travel    @relation("TravelImages", fields: [travelId], references: [id], onDelete: Cascade)
  url         String
  sort        Int       @default(0)
  
  createdAt   DateTime  @default(now())
}

model TravelLike {
  id          String    @id @default(uuid())
  travelId    String
  travel      Travel    @relation(fields: [travelId], references: [id], onDelete: Cascade)
  userId      String
  
  createdAt   DateTime  @default(now())
  
  @@unique([travelId, userId])
  @@index([travelId])
}

// ==================== 心愿相关 ====================

model Wish {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        WishType
  title       String
  description String?     @db.Text
  content     String      @db.Text
  images      Json        @default("[]")
  tags        Json        @default("[]")
  
  expectTime  ExpectTime
  expectPeople ExpectPeople
  
  status      WishStatus  @default(COLLECTING)
  expiresAt   DateTime?
  supportCount Int       @default(0)  // 支持人数
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  supports    WishSupport[]
  
  @@index([userId])
  @@index([status])
}

model WishSupport {
  id          String    @id @default(uuid())
  wishId      String
  wish        Wish      @relation(fields: [wishId], references: [id], onDelete: Cascade)
  userId      String
  
  createdAt   DateTime  @default(now())
  
  @@unique([wishId, userId])
  @@index([wishId])
}

// ==================== 互助相关 ====================

model Help {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title       String
  content     String      @db.Text
  description String?     @db.Text  // 描述
  images      Json        @default("[]")
  
  type        String?     // 互助类型
  category    String?
  location    String?
  
  status      HelpStatus  @default(ACTIVE)
  resolvedAt  DateTime?
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  responses   HelpResponse[]
  
  @@index([userId])
  @@index([status])
}

model HelpResponse {
  id          String    @id @default(uuid())
  helpId      String
  help        Help      @relation(fields: [helpId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  content     String    @db.Text
  contact     String?
  message     String?   @db.Text  // 留言内容（与content相同）
  
  createdAt   DateTime  @default(now())
  
  @@index([helpId])
}

// ==================== 反馈相关 ====================

enum FeedbackStatus {
  PENDING     // 待处理
  PROCESSING  // 处理中
  RESOLVED    // 已解决
  REJECTED   // 已拒绝
}

enum FeedbackType {
  BUG         // 功能异常
  SUGGEST     // 建议反馈
  COMPLAINT   // 投诉
  OTHER       // 其他
}

model Feedback {
  id          String        @id @default(uuid())
  userId      String?
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  type        FeedbackType  @default(SUGGEST)
  content     String        @db.Text
  contact     String?       // 联系方式
  
  status      FeedbackStatus @default(PENDING)
  reply       String?       @db.Text  // 回复内容
  repliedAt   DateTime?
  repliedBy   String?       // 回复人
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([type])
}

// ==================== 邀请相关 ====================

model InviteRelation {
  id          String    @id @default(uuid())
  inviterId   String
  inviteeId   String
   
  // 兼容字段
  inviteCode  String?   // 邀请码（兼容）
  registeredAt DateTime @default(now())  // 注册时间
   
  inviter     User      @relation("InviterRelations", fields: [inviterId], references: [id], onDelete: Cascade, map: "InviteRelation_inviterId_fkey")
  invitee     User      @relation("InviteeRelations", fields: [inviteeId], references: [id], onDelete: Cascade, map: "InviteRelation_inviteeId_fkey")
   
  createdAt   DateTime  @default(now())
    
  @@unique([inviterId, inviteeId])
  @@index([inviterId])
  @@index([inviteeId])
}

// 邀请奖励记录
model InviteReward {
  id          String    @id @default(uuid())
  userId      String    // 获得奖励的用户（邀请人）
  inviterId   String?   // 邀请人ID
  inviteeId   String?   // 被邀请人ID
  type        String    // REGISTER:注册奖励, FIRST_ACTIVITY:首次活动奖励
  amount      Decimal   @db.Decimal(10, 2)
  currency    String    @default("CNY")
  status      String    @default("PAID") // PENDING | PAID | FAILED
  orderId     String?   // 关联订单（活动奖励时）
  
  createdAt   DateTime  @default(now())
  
  @@index([userId])
  @@index([inviterId])
  @@index([inviteeId])
}

// 推广大使状态
enum PromoterStatus {
  ACTIVE
  DISABLED
}

// 奖励类型
enum RewardType {
  FIRST_ACTIVITY  // 首次活动奖励
  ACTIVITY        // 活动奖励
}

// 奖励状态
enum RewardStatus {
  PENDING   // 待结算
  SETTLED   // 已结算（可提现）
  WITHDRAWN // 已提现
}

// 推广大使
model Promoter {
  id              String        @id @default(uuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  totalEarnings   Decimal       @default(0) @db.Decimal(10, 2) // 累计收益
  pendingEarnings Decimal       @default(0) @db.Decimal(10, 2) // 待结算收益
  withdrawnAmount Decimal       @default(0) @db.Decimal(10, 2) // 已提现收益
  
  status          PromoterStatus @default(ACTIVE)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  rewards         PromoterReward[]
  
  @@index([status])
}

// 推广大使奖励记录
model PromoterReward {
  id            String        @id @default(uuid())
  promoterId    String
  promoter      Promoter      @relation(fields: [promoterId], references: [id], onDelete: Cascade)
  
  type          RewardType    // FIRST_ACTIVITY | ACTIVITY
  amount        Decimal       @db.Decimal(10, 2)
  status        RewardStatus  @default(PENDING)
  
  // 关联活动信息
  activityId    String?
  activityTitle String?
  userId        String?       // 被邀请用户ID
  
  settledAt     DateTime?     // 结算时间
  withdrawnAt   DateTime?     // 提现时间
  
  createdAt     DateTime      @default(now())
  
  @@index([promoterId])
  @@index([status])
  @@index([activityId])
}
